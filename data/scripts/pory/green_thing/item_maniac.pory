}

script Pory_EventScript_GoldManiac_DoBigNuggets {
  showmoneybox(0, 0)
  checkitem(ITEM_BIG_NUGGET, 2)
  if (var(VAR_RESULT)) {
    msgbox(format("Wow! A knowledgeable investor like me! You looking to liquidate some of those Big Nuggets? How about… ¥40000 for one?"), MSGBOX_YESNO)
  } else {
    msgbox(format("Look of the size of that Big Nugget! Hey, what would you said if I offered you ¥40000 for it?"), MSGBOX_YESNO)
  }
  if (var(VAR_RESULT)) {
    msgbox(format("{PLAYER} handed the Big Nugget to the man. He smells of cheap cologne."))
    removeitem(ITEM_BIG_NUGGET)
    addmoney(40000)
    updatemoneybox
    playse(SE_SHOP)
    msgbox(format("Thank you! Thank you! Thank you! Haha!"))
  } else {
    call(Pory_EventScript_GoldManiac_Declinations)
  }
  hidemoneybox
}

script Pory_EventScript_GoldManiac_DoNuggets {
  showmoneybox(0, 0)
  checkitem(ITEM_NUGGET, 2)
  if (var(VAR_RESULT)) {
    msgbox(format("I know precious metals when I see them! I'll give you ¥10000 for one of those Nuggets, how's that sound?"), MSGBOX_YESNO)
  } else {
    msgbox(format("A Nugget! Gold is gold, and ¥10000 is ¥10000. How's that offer sound?"), MSGBOX_YESNO)
  }
  if (var(VAR_RESULT)) {
    msgbox(format("{PLAYER} handed the Nugget to the man. He shoves it in his coat pocket."))
    removeitem(ITEM_NUGGET)
    addmoney(10000)
    updatemoneybox
    playse(SE_SHOP)
    msgbox(format("Sold!"))
  } else {
    call(Pory_EventScript_GoldManiac_Declinations)
  }
  hidemoneybox
}
